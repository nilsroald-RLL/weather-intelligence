# Environment configuration for Weather Intelligence
#
# Copy this file to .env.local and fill in real values. Do not commit .env.local.
# The application validates these at startup using an environment schema.
# Storm variables are only required when Storm is enabled.

# --- App ---
# Public display name for the app.
NEXT_PUBLIC_APP_NAME=Weather Intelligence

# Timezone used for display and daily aggregation. Storage stays in UTC.
APP_TIMEZONE=Europe/Oslo

# --- Supabase ---
# Project URL and public anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key is server-side only. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- MET Norway (Yr forecasts) ---
# Descriptive User-Agent required by MET Norway terms. Include an app name and a
# contact address, for example: "weather-intelligence/1.0 contact@example.com"
MET_USER_AGENT=

# --- MET Norway Frost (observations) ---
# Frost client id for actual observed weather.
FROST_CLIENT_ID=

# --- Storm (optional) ---
# Controls how Storm data is sourced. Suggested values:
#   disabled  = run in Yr-only mode with a visible Storm placeholder
#   mock      = use MockStormProvider during development
#   api       = use a configured Storm or licensed provider API
# Do not require the variables below when STORM_PROVIDER_MODE=disabled.
STORM_PROVIDER_MODE=disabled
STORM_API_BASE_URL=
STORM_API_KEY=

# --- Scheduled jobs ---
# Shared secret used to protect job endpoints so only the scheduler can trigger them.
CRON_SECRET=
